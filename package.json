{
  "name": "codex-github-router",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "Routes GitHub events to Codex",
  "bin": {
    "codex-github-router": "./bin/codex-github-router.js"
  },
  "files": [
    "bin",
    "dist",
    "README.md",
    "SECURITY.md",
    "LICENSE"
  ],
  "author": {
    "name": "Ted Mader",
    "email": "ted@patinaproject.com",
    "url": "https://github.com/tlmader"
  },
  "license": "MIT",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=24",
    "pnpm": ">=10"
  },
  "scripts": {
    "prepare": "husky",
    "commit": "git-cz",
    "commit:retry": "git-cz --retry",
    "commitlint": "commitlint",
    "lint:md": "markdownlint-cli2 \"**/*.md\" \"#node_modules\" \"#skills/**\" \"#.agents/skills/**\" \"#.claude/skills/**\"",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test \"test/**/*.test.ts\"",
    "prepack": "pnpm build",
    "pack:dry-run": "npm pack --dry-run",
    "skills:restore": "bash scripts/install-third-party-skills.sh",
    "skills:update": "npx --yes skills@latest update --project --yes"
  },
  "config": {
    "commitizen": {
      "path": "cz-customizable"
    },
    "cz-customizable": {
      "config": "commitizen.config.json"
    }
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@types/node": "^25.9.1",
    "commitizen": "^4.3.1",
    "cz-customizable": "^7.5.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "markdownlint-cli2": "^0.14.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@clack/prompts": "^1.4.0"
  }
}
